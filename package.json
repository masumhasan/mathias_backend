    "helmet": "^7.1.0",
    "imapflow": "^1.0.162",
    "jsonwebtoken": "^9.0.3",
    "mailparser": "^3.7.1",
    "mongoose": "^8.4.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^9.0.0",
    "openai": "^4.52.7",
    "winston": "^3.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mailparser": "^3.4.4",
    "@types/node": "^20.14.9",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.1",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "eslint": "^8.57.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.3"
